# HAR Analyzer Hosted Worker
# Replace placeholders through Hosted Application configuration and approved secrets.
# Do not upload a populated copy to source control or Slack.

NODE_ENV=production
HOSTED_DEPLOYMENT=true
HOST=0.0.0.0
WORKER_CONCURRENCY=2

DATABASE_URL=<secret:oci-postgresql-connection-uri>
POSTGRES_SSL_MODE=verify-full
POSTGRES_SSL_CA_BASE64=<secret:oci-postgresql-ca-base64>
POSTGRES_POOL_MAX=20
POSTGRES_CONNECT_TIMEOUT_MS=10000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=60000

REDIS_URL=<secret:oci-cache-rediss-uri>

ARTIFACT_STORE=oci-object-storage
OCI_OBJECT_STORAGE_NAMESPACE=<oci-object-storage-namespace>
OCI_OBJECT_STORAGE_BUCKET=<har-analyzer-bucket>
OCI_OBJECT_STORAGE_PREFIX=har-analyzer
OCI_AUTH_MODE=resource-principal

