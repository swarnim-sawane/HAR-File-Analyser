PORT=4000
WORKER_HEALTH_PORT=4001
HOST=0.0.0.0
HOSTED_DEPLOYMENT=false
PUBLIC_API_URL=http://localhost:4000
OPENAPI_SERVER_URL=http://localhost:4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/har_analyzer
POSTGRES_SSL_MODE=disable
POSTGRES_SSL_CA=
POSTGRES_SSL_CA_BASE64=
POSTGRES_SSL_CA_FILE=
POSTGRES_POOL_MAX=20
POSTGRES_CONNECT_TIMEOUT_MS=10000
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_STATEMENT_TIMEOUT_MS=60000
# Hosted deployments can inject a complete rediss:// connection URI here.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_TLS_SERVERNAME=
REDIS_TLS_CA=
REDIS_TLS_CA_BASE64=
REDIS_TLS_CA_FILE=

UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
ARTIFACT_SCRATCH_DIR=./uploads/assembled
WORKER_SCRATCH_DIR=./uploads/worker
SANITIZE_SCRATCH_DIR=./uploads/sanitize

# local for development; oci-object-storage for OCI Hosted Deployment.
ARTIFACT_STORE=local
ARTIFACT_LOCAL_DIR=./processed
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
OCI_OBJECT_STORAGE_PREFIX=har-analyzer
# Hosted Deployment uses resource-principal. config-file is available for local OCI testing.
OCI_AUTH_MODE=resource-principal
OCI_CONFIG_FILE=
OCI_CONFIG_PROFILE=DEFAULT
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
JSON_BODY_LIMIT=10mb

# Defaults to https://api.openai.com/v1 when omitted. Set only for an approved gateway.
OPENAI_BASE_URL=
OPENAI_API_KEY=
# Use the exact model approved for this governed key. No model is assumed by the backend.
OPENAI_MODEL=
# Provider-reported token usage is persisted in PostgreSQL when enabled.
AI_USAGE_TRACKING_ENABLED=true
# Configure approved/negotiated USD rates per 1 million tokens for cost estimates.
# If the cached-input rate is omitted, the normal input rate is used and reported as a fallback.
OPENAI_INPUT_USD_PER_1M_TOKENS=
OPENAI_CACHED_INPUT_USD_PER_1M_TOKENS=
OPENAI_OUTPUT_USD_PER_1M_TOKENS=
HTTPS_PROXY=
HTTP_PROXY=

RETENTION_CLEANUP_ENABLED=false
RETENTION_MAX_AGE_HOURS=168
RETENTION_CLEANUP_INTERVAL_MINUTES=60
RETENTION_CLEANUP_DRY_RUN=true

OBSERVABILITY_STORAGE_WARN_BYTES=5368709120
