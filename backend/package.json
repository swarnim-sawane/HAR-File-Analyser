{
  "name": "har-analyzer-backend",
  "version": "1.0.0",
  "description": "Backend API for HAR File Analyzer",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:worker": "nodemon --exec ts-node src/worker.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.8.0",
    "axios": "^1.6.5",
    "body-parser": "^1.20.2",
    "bullmq": "^5.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "JSONStream": "1.3.4",
    "mongodb": "^6.3.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.1",
    "through2": "^4.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonstream": "^0.8.33",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/through2": "^2.0.41",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.2",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
